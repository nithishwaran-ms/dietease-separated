<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include all SharedPreferences for cloud backup (login + logs + products) -->
        <include domain="sharedpref" path="dietease_prefs.xml"/>
        <include domain="sharedpref" path="dietease_log.xml"/>
        <include domain="sharedpref" path="dietease_products.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="dietease_prefs.xml"/>
        <include domain="sharedpref" path="dietease_log.xml"/>
        <include domain="sharedpref" path="dietease_products.xml"/>
    </device-transfer>
</data-extraction-rules>